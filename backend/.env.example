# Environment
NODE_ENV=development
PORT=3001

# Database — SQLite local. En prod: postgresql://user:pass@host:5432/db
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET=change-me-in-production-please-use-a-strong-random-secret
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=12

# CORS — origenes permitidos separados por coma
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# Swagger
SWAGGER_PATH=api/docs
