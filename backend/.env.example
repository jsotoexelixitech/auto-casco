# Environment
NODE_ENV=development
PORT=3001

# Database — PostgreSQL (dev local y prod)
DATABASE_URL="postgresql://auto_casco_app:CHANGE_ME@localhost:5432/auto_casco?schema=public"

# Auth
JWT_SECRET=change-me-in-production-please-use-a-strong-random-secret
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=12

# CORS — origenes permitidos separados por coma
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# Swagger
SWAGGER_PATH=api/docs
