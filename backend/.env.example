# Environment
NODE_ENV=development
PORT=3001

# Database — PostgreSQL (dev local y prod)
DATABASE_URL="postgresql://auto_casco_app:CHANGE_ME@localhost:5432/auto_casco?schema=public"

# Auth
JWT_SECRET=change-me-in-production-please-use-a-strong-random-secret
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=12

# CORS — origenes permitidos separados por coma
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# Swagger
SWAGGER_PATH=api/docs

# Google Gemini (IA — inspección vehicular y OCR)
GEMINI_API_KEY=tu-key-aqui
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro

# Rate limiting específico para endpoints /ai/*
AI_THROTTLE_TTL=60
AI_THROTTLE_LIMIT=20

# OCR — imágenes de referencia visual (solo layout, nunca datos de salida)
OCR_REFERENCE_ENABLED=true
OCR_REFERENCE_DOCS_DIR=./examples/docs

# Nexus Pagos (SSO + callback)
# NEXUS_API_URL=https://cierrelmds.exelixitech.com/nexus-api
NEXUS_API_URL=
NEXUS_API_KEY=

# URL pública HTTPS que Pagos-API pueda alcanzar (en local usa túnel → Nest)
# NEXUS_NOTIFY_URL=https://xxxx.ngrok-free.app/api/v1/payments/checkout/notify
NEXUS_NOTIFY_URL=
NEXUS_PAGOS_CANAL=27
