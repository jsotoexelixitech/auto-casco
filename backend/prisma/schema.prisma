// Auto Casco — La Mundial de Seguros
// Prisma schema — PostgreSQL
// IDs: correlativos Int @default(autoincrement()) — no cuid

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  legacyId     String?  @unique
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("asegurado")
  title        String?
  avatar       String?
  color        String?
  phone        String?
  documento    String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vehicles       Vehicle[]
  policies       Policy[]
  inspections    Inspection[]   @relation("PeritoInspections")
  paymentMethods PaymentMethod[]

  @@index([email])
  @@index([role])
}

model Vehicle {
  id          Int      @id @default(autoincrement())
  legacyId    String?  @unique
  placa       String   @unique
  marca       String
  modelo      String
  version     String?
  anio        Int
  color       String?
  tipo        String?
  puestos     Int?
  serial      String?  @unique
  image       String?
  kilometraje Int?
  ownerId     Int
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  policies    Policy[]
  inspections Inspection[]
  siniestros  Siniestro[]

  @@index([ownerId])
  @@index([placa])
}

model Plan {
  id          Int      @id @default(autoincrement())
  legacyId    String?  @unique
  nombre      String
  descripcion String?
  precioDia   Float
  icon        String?
  features    String   @default("[]") // JSON array of feature strings
  recomendado Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  policies Policy[]
}

model Policy {
  id              Int      @id @default(autoincrement())
  legacyId        String?  @unique
  numero          String   @unique
  estado          String   @default("Activa")
  planNombre      String?                         // "Básico" | "Estándar" | "Premium"
  modalidad       String   @default("dias")
  diasContratados Int      @default(0)
  diasRestantes   Int      @default(0)
  saldoDisponible Float    @default(0)
  prima           Float    @default(0)
  coberturas      String   @default("[]")         // JSON: [{nombre, limite}]
  urlPoliza       String?                         // PDF Valrep (urlpoliza)
  cnRecibo        String?                         // Recibo Valrep (cnrecibo)
  fechaInicio     DateTime @default(now())
  fechaFin        DateTime?
  vehicleId       Int
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  holderId        Int
  holder          User     @relation(fields: [holderId], references: [id], onDelete: Cascade)
  planId          Int?
  plan            Plan?    @relation(fields: [planId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pagos      Payment[]
  siniestros Siniestro[]

  @@index([holderId])
  @@index([vehicleId])
  @@index([estado])
}

model Inspection {
  id               Int      @id @default(autoincrement())
  legacyId         String?  @unique
  numero           String   @unique
  tipo             String   @default("inicial")
  estado           String   @default("borrador")
  vehicleId        Int
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  peritoId         Int?
  perito           User?    @relation("PeritoInspections", fields: [peritoId], references: [id])
  ubicacion        String?
  latitude         Float?
  longitude        Float?
  fotos            String   @default("[]")
  danios           String   @default("[]")
  video360Url      String?
  observaciones    String?
  fechaCaptura     DateTime @default(now())
  fechaAprobacion  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([vehicleId])
  @@index([peritoId])
  @@index([estado])
}

model Payment {
  id        Int      @id @default(autoincrement())
  legacyId  String?  @unique
  policyId  Int?
  policy    Policy?  @relation(fields: [policyId], references: [id], onDelete: SetNull)
  userId    Int?
  concepto  String
  metodo    String   @default("Saldo")
  monto     Float
  estado    String   @default("Completado")
  fecha     DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([policyId])
  @@index([userId])
  @@index([estado])
}

model PaymentMethod {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // card | transfer | pago-movil
  label     String
  sub       String?
  icon      String   @default("credit_card")
  isPrimary Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Siniestro {
  id          Int      @id @default(autoincrement())
  legacyId    String?  @unique
  numero      String   @unique
  policyId    Int
  policy      Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  vehicleId   Int
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  tipo        String   @default("Choque Frontal")
  severidad   String   @default("moderado")
  estado      String   @default("En Análisis")
  descripcion String?
  lugar       String?
  hora        String?
  heridos     Boolean  @default(false)
  autoridad   Boolean  @default(false)
  monto       Float    @default(0)
  avance      Int      @default(10)
  fechaEvento DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([policyId])
  @@index([vehicleId])
  @@index([estado])
}
