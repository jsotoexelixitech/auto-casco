# URL del servidor backend de Nexus (exelixi-nexus-services) — acceso PWA
# VITE_NEXUS_API_URL=http://192.168.8.120:3092
VITE_NEXUS_API_URL=http://localhost:3001

# Backend NestJS (Auto Casco)
VITE_API_URL=/api/v1

# Valrep — base estable de la API (sin barra final).
# En desarrollo puedes usar /valrep-api (proxy Vite → evita CORS).
# En red directa: http://192.168.8.120:3002/api/v1
VITE_VALREP_API_URL=/valrep-api

# Pagos SSO: la URL del iframe se obtiene vía Nest → Nexus (no hardcodear).
# Callback browser (redirect):
#   http://TU_IP_LAN:5173/pago/resultado?idOperacion=OP-...
# VITE_PAYMENT_REDIRECT_ORIGIN=http://192.168.10.215:5173
#
# Notify (webhook que Pagos llama a Nest). Sin ngrok si Pagos está en la misma LAN:
#   NEXUS_NOTIFY_URL=http://192.168.10.215:3001/api/v1/payments/checkout/notify
# Si Nexus/Pagos está en internet (ej. cierrelmds.exelixitech.com), esa máquina
# NO puede alcanzar IPs privadas: ahí sí hace falta túnel o IP pública.
